# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase. Formato: https://<project-ref>.supabase.co
SUPABASE_URL=https://tu-projecto.supabase.co

# Clave anónima (anon key) del proyecto Supabase.
# La encontrás en Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=tu-anon-key

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# API Key de OpenAI. La generás en platform.openai.com → API keys.
OPENAI_API_KEY=tu-api-key

# Modelo a usar. Se recomienda gpt-4o-mini por costo/performance.
# Cambiarlo a modelos más grandes puede incrementar la latencia y el costo.
OPENAI_MODEL=gpt-4o-mini

# ─── Umbrales de señal de recomendación (en %) ───────────────────────────────
# Estos valores calibran cuándo el agente emite señal "comprar", "esperar" o "neutral".
# Se calculan sobre el spread (diferencia compra-venta) y la brecha contra el dólar oficial.
# Los valores por defecto están calibrados a junio 2026, post-salida del cepo.
# Ajustarlos si el mercado cambia de régimen.

# Spread alto: a partir de este % el mercado se considera caro para operar
UMBRAL_SPREAD_ALTO=2.5

# Spread bajo: por debajo de este % el mercado se considera competitivo
UMBRAL_SPREAD_BAJO=1.5

# Brecha alta: brecha % vs oficial a partir de la cual se recomienda esperar
UMBRAL_BRECHA_ALTA=8

# Brecha baja: brecha % vs oficial por debajo de la cual la señal es favorable
UMBRAL_BRECHA_BAJA=3
