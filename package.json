      "<rootDir>/jest.setup.js"
    ],
    "forceExit": true
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "openai": "^6.42.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-typescript": "^7.24.0",
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "babel-jest": "^29.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
