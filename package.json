{
  "name": "asesor-de-cambio-de-divisas",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "test": "jest --detectOpenHandles",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
